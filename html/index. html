<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Fashion World - Xu hướng Thời trang</title>
    <link rel="stylesheet" href="../css/style.css">
    <!-- Nhúng thư viện JQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>

    <!-- MENU ĐIỀU HƯỚNG -->
    <header>
        <nav class="main-menu">
            <div class="logo">FASHION HUB</div>
            <ul>
                <li><a href="index.html" class="active">Trang Chủ</a></li>
                <li><a href="tin-tuc.html">Tin Tức</a></li>
                <li><a href="su-kien.html">Sự Kiện</a></li>
                <li><a href="xu-huong.html">Xu Hướng</a></li>
                <li><a href="lam-dep.html">Làm Đẹp</a></li>
            </ul>
        </nav>
    </header>

    <!-- BANNER CHÍNH (Có tương tác) -->
    <section class="hero-banner">
        <div class="slide">Khám Phá Phong Cách Thời Trang 2026</div>
    </section>

    <!-- PHÂN VÙNG CÁC CHỦ ĐỀ CHÍNH -->
    <main class="container">
        
        <!-- Chủ đề 1: Tin Tức -->
        <section class="topic-box" id="news-section">
            <h2>Tin Tức Thời Trang</h2>
            <p>Cập nhật những thông tin, biến động và câu chuyện thời trang nóng hổi trong và ngoài nước...</p>
            <a href="tin-tuc.html" class="btn">Xem tất cả tin tức</a>
        </section>

        <!-- Chủ đề 2: Sự Kiện -->
        <section class="topic-box" id="event-section">
            <h2>Sự Kiện Nổi Bật</h2>
            <p>Theo dòng các tuần lễ thời trang danh giá (Fashion Week), các buổi triển lãm và show diễn lớn toàn cầu...</p>
            <a href="su-kien.html" class="btn">Xem sự kiện</a>
        </section>

        <!-- Chủ đề 3: Xu Hướng -->
        <section class="topic-box" id="trend-section">
            <h2>Xu Hướng Mới</h2>
            <p>Khám phá các xu hướng thu đông, xuân hè, phong cách streetstyle thịnh hành đang dẫn dắt thị trường...</p>
            <a href="xu-huong.html" class="btn">Khám phá xu hướng</a>
        </section>

        <!-- Chủ đề 4: Làm Đẹp -->
        <section class="topic-box" id="beauty-section">
            <h2>Bí Quyết Làm Đẹp</h2>
            <p>Chăm sóc da, xu hướng trang điểm đột phá phối hợp hoàn hảo cùng các bộ cánh thời thượng...</p>
            <a href="lam-dep.html" class="btn">Bí quyết làm đẹp</a>
        </section>

        <!-- KHU VỰC BÌNH LUẬN & PHẢN HỒI Ý KIẾN -->
        <section class="comment-section">
            <h3>Bình luận & Góp ý</h3>
            <form id="commentForm">
                <input type="text" id="userName" placeholder="Tên của bạn" required>
                <textarea id="commentContent" placeholder="Ý kiến của bạn về chủ đề này..." required></textarea>
                <button type="submit">Gửi bình luận</button>
            </form>
            <div id="commentList">
                <!-- Bình luận sẽ tự động thêm vào đây bằng JQuery -->
            </div>
        </section>

    </main>

    <!-- FOOTER & SITE MAP -->
    <footer>
        <div class="footer-content">
            <div class="sitemap">
                <h4>SITE MAP (Sơ đồ trang)</h4>
                <ul>
                    <li><a href="index.html">Trang Chủ</a></li>
                    <li><a href="tin-tuc.html">Tin Tức Trong & Ngoài Nước</a></li>
                    <li><a href="su-kien.html">Tuần lễ Thời trang & Sự kiện</a></li>
                    <li><a href="xu-huong.html">Xu Hướng Phối Đồ</a></li>
                    <li><a href="lam-dep.html">Bí quyết Làm Đẹp</a></li>
                </ul>
            </div>
        </div>
        <p>&copy; 2026 Fashion Hub. All rights reserved.</p>
    </footer>

    <script src="../js/main.js"></script>
</body>
</html>
